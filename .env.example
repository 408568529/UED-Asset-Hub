NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_USE_MOCK=true
# Keep host runtime data outside the Git checkout.
# macOS/Linux example: DATA_DIR=/UED-Asset-Hub-Storage/data
# Windows example: DATA_DIR=D:/UED-Asset-Hub/data
DATA_DIR=/UED-Asset-Hub-Storage/data
# Only files inside this directory can be associated with Training Library.
# Windows example: TRAINING_MEDIA_DIR=D:/UED-Asset-Hub/training-media
TRAINING_MEDIA_DIR=/UED-Asset-Hub-Storage/training-media
# Server-only encryption secret for test environment passwords.
TEST_ENV_ENCRYPTION_KEY=
# Admin credentials and session signing stay on the server. Do not use NEXT_PUBLIC_ variables here.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# Use a long random value in a shared environment.
ADMIN_SESSION_SECRET=
# Set true only when the server is accessed through HTTPS.
ADMIN_SESSION_SECURE=false

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

NEXT_PUBLIC_STORAGE_PROVIDER=local
NEXT_PUBLIC_OSS_BUCKET=
NEXT_PUBLIC_OSS_REGION=
